---
import '../styles/global.css';

interface Props {
  title?: string;
  pageId?: string;
  description?: string;
  ogType?: 'website' | 'article';
}

const defaultDescription = 'fumi の個人ブログ。学習・所感・技術ログ。';
const {
  title = '/fumi/notes',
  pageId = 'home',
  description = defaultDescription,
  ogType = 'website',
} = Astro.props;
const today = new Date().toISOString().slice(0, 10);
const year = new Date().getFullYear();
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="Wbcj__25HuU4WdD_QhAGtNNvUU3szggb6VWLUzIlhZ8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="/fumi/notes" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="top-bar">
      <span class="site-tag">/fumi/notes</span>
      <span class="dim">[0]</span>
      <a href="/" class={pageId === 'home' ? 'win-active' : 'dim'}>1:home{pageId === 'home' ? '*' : ''}</a>
      <a href="/posts/" class={pageId === 'posts' ? 'win-active' : 'dim'}>2:posts{pageId === 'posts' ? '*' : ''}</a>
      <a href="/tags/" class={`${pageId === 'tags' ? 'win-active' : 'dim'} win-tags`}>3:tags{pageId === 'tags' ? '*' : ''}</a>
      <a href="/about" class={`${pageId === 'about' ? 'win-active' : 'dim'} win-about`}>4:about{pageId === 'about' ? '*' : ''}</a>
      <a href="/search" class={`${pageId === 'search' ? 'win-active' : 'dim'} win-search`}>5:search{pageId === 'search' ? '*' : ''}</a>
      <span class="spacer"></span>
    </div>

    <slot />

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const blocks = document.querySelectorAll<HTMLPreElement>('.article-body pre');
        blocks.forEach((pre) => {
          const button = document.createElement('button');
          button.className = 'code-copy';
          button.type = 'button';
          button.textContent = 'copy';
          button.setAttribute('aria-label', 'コードをコピー');
          button.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';
            try {
              await navigator.clipboard.writeText(code);
              button.textContent = 'copied';
              button.classList.add('copied');
              setTimeout(() => {
                button.textContent = 'copy';
                button.classList.remove('copied');
              }, 1500);
            } catch {
              button.textContent = 'failed';
              setTimeout(() => { button.textContent = 'copy'; }, 1500);
            }
          });
          pre.appendChild(button);
        });
      });
    </script>

    <div class="bottom-bar">
      <span class="spacer"></span>
      <span>/fumi/notes</span>
      <span class="sep-pipe">|</span>
      <span>{today}</span>
      <span class="sep-pipe">|</span>
      <span>© {year}</span>
    </div>
  </body>
</html>
