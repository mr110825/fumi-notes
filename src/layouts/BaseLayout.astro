---
import '../styles/global.css';

interface Props {
  title?: string;
  pageId?: string;
  description?: string;
  ogType?: 'website' | 'article';
}

const defaultDescription = 'fumi の個人ブログ。学習・所感・技術ログ。';
const {
  title = '/fumi/notes',
  pageId = 'home',
  description = defaultDescription,
  ogType = 'website',
} = Astro.props;
const today = new Date().toISOString().slice(0, 10);
const year = new Date().getFullYear();
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content="/fumi/notes" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="top-bar">
      <span class="site-tag">/fumi/notes</span>
      <span class="dim">[0]</span>
      <a href="/" class={pageId === 'home' ? 'win-active' : 'dim'}>1:home{pageId === 'home' ? '*' : ''}</a>
      <a href="/articles" class={pageId === 'articles' ? 'win-active' : 'dim'}>2:articles{pageId === 'articles' ? '*' : ''}</a>
      <a href="/tags/" class={`${pageId === 'tags' ? 'win-active' : 'dim'} win-tags`}>3:tags{pageId === 'tags' ? '*' : ''}</a>
      <a href="/about" class={`${pageId === 'about' ? 'win-active' : 'dim'} win-about`}>4:about{pageId === 'about' ? '*' : ''}</a>
      <span class="spacer"></span>
      <span class="dim size-desktop">132×42</span>
      <span class="dim size-mobile">40×60</span>
    </div>

    <slot />

    <div class="bottom-bar">
      <span class="mode-tag">[normal]</span>
      <a href="https://github.com/mr110825/fumi-notes">github</a>
      <span class="sep">·</span>
      <a href="/about">about</a>
      <span class="sep">·</span>
      <a href="/rss.xml">rss</a>
      <span class="spacer"></span>
      <span>/fumi/notes</span>
      <span class="sep">·</span>
      <span>{today}</span>
      <span class="sep">·</span>
      <span>© {year}</span>
    </div>
  </body>
</html>
