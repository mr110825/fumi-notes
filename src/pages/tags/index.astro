---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = await getCollection('blog', ({ data }) => !data.draft);

const tagCounts = new Map<string, number>();
for (const entry of all) {
  for (const tag of entry.data.tags) {
    const key = tag.replace(/^#/, '').toLowerCase();
    tagCounts.set(key, (tagCounts.get(key) ?? 0) + 1);
  }
}

const tagDefs = [
  { num: '01', slug: 'aws',          label: '#aws',          blurb: 'VPC / IAM / EKS 周辺' },
  { num: '02', slug: 'terraform',    label: '#terraform',    blurb: 'module 設計・state の事故' },
  { num: '03', slug: 'linux',        label: '#linux',        blurb: 'systemd・名前解決・tcpdump' },
  { num: '04', slug: 'network',      label: '#network',      blurb: 'TCP/IP を自分に説明し直す' },
  { num: '05', slug: 'security',     label: '#security',     blurb: 'IAM・sts・policy の読み方' },
  { num: '06', slug: 'teaching',     label: '#teaching',     blurb: '新卒研修・入門解説の副産物' },
  { num: '07', slug: 'fundamentals', label: '#fundamentals', blurb: '毎年描き直す基礎' },
  { num: '08', slug: 'jot',          label: '#jot',          blurb: '今日知った小さなこと' },
];
const tags = tagDefs.map((t) => ({
  ...t,
  count: tagCounts.get(t.slug) ?? 0,
}));
---

<BaseLayout title="tags — /fumi/notes" pageId="tags">
  <main class="main">
    <div class="left-col">
      <section class="pane tags-pane">
        <div class="pane-header">
          <span class="marker">■</span>
          <span class="title">~/tags</span>
          <span class="sep">·</span>
          <span>{tags.length} tags</span>
          <span class="spacer"></span>
          <span class="controls">─ □ ×</span>
        </div>
        <div class="pane-body">
          <ul class="tags-list">
            {tags.map((tag) => (
              <li>
                <a href={`/tags/${tag.slug}/`} class="tag-row">
                  <span class="tag-num">{tag.num}</span>
                  <span class="tag-label">{tag.label}</span>
                  <span class="tag-blurb">{tag.blurb}</span>
                  <span class="tag-count">{tag.count}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
