---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="search — /fumi/notes" pageId="search" description="記事の全文検索。">
  <main class="main">
    <div class="left-col">
      <section class="pane hero-pane">
        <div class="pane-header">
          <span class="marker">■</span>
          <span class="title">~/search</span>
          <span class="sep">·</span>
          <span>search.txt</span>
          <span class="spacer"></span>
          <span class="controls">─ □ ×</span>
        </div>
        <div class="pane-body">
          <div class="hero-title"><span class="cursor">❯</span> search</div>
          <p class="hero-tagline">// 全記事を全文検索(タイトル・本文・タグ・コードブロック)</p>
          <div id="search"></div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      resetStyles: false,
      translations: {
        placeholder: '記事を検索...',
        clear_search: 'クリア',
        load_more: 'さらに読み込む',
        search_label: '検索',
        filters_label: 'フィルタ',
        zero_results: '[0]/[1] にヒットなし',
        many_results: '[0]/[1] 件',
        one_result: '[0]/[1] 件',
        alt_search: '[0] にヒットなし。代わりに [1] で検索しました',
        search_suggestion: '[0] にヒットなし。次のクエリを試してください',
        searching: '[0] を検索中...',
      },
    });
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--rule);
    --pagefind-ui-tag: var(--status);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: var(--mono);
  }

  #search { margin-top: 0.75rem; }

  /* ── Form & prompt ─────────────────────────────── */
  #search .pagefind-ui__form { position: relative; }
  /* デフォルトの虫眼鏡SVGを ❯ プロンプトに差し替え */
  #search .pagefind-ui__form::before {
    content: "❯";
    -webkit-mask-image: none;
    mask-image: none;
    background-color: transparent;
    color: var(--accent);
    font-family: var(--mono);
    font-weight: 700;
    font-size: calc(20px * var(--pagefind-ui-scale));
    line-height: 1;
    width: auto;
    height: auto;
    top: 50%;
    left: calc(16px * var(--pagefind-ui-scale));
    transform: translateY(-50%);
    opacity: 1;
    pointer-events: none;
  }

  /* ── Search input ──────────────────────────────── */
  #search .pagefind-ui__search-input {
    height: calc(48px * var(--pagefind-ui-scale));
    padding: 0 calc(80px * var(--pagefind-ui-scale)) 0 calc(40px * var(--pagefind-ui-scale));
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--rule);
    border-radius: 0;
    font-family: var(--mono);
    font-weight: 400;
    font-size: calc(16px * var(--pagefind-ui-scale));
    letter-spacing: 0;
    transition: border-color 0.12s, box-shadow 0.12s;
  }
  #search .pagefind-ui__search-input::placeholder {
    color: var(--faint);
    opacity: 1;
    font-weight: 400;
  }
  #search .pagefind-ui__search-input:focus {
    outline: 0;
    border-color: var(--accent);
    box-shadow: inset 0 0 0 1px var(--accent);
  }

  /* ── Clear button (terminal key風) ──────────────── */
  #search .pagefind-ui__search-clear {
    top: 50%;
    right: calc(8px * var(--pagefind-ui-scale));
    transform: translateY(-50%);
    height: calc(26px * var(--pagefind-ui-scale));
    padding: 0 calc(10px * var(--pagefind-ui-scale));
    background: var(--status);
    border: 1px solid var(--rule);
    border-radius: 0;
    color: var(--dim);
    font-family: var(--mono);
    font-size: calc(12px * var(--pagefind-ui-scale));
    letter-spacing: 0.04em;
    transition: color 0.1s, border-color 0.1s;
  }
  #search .pagefind-ui__search-clear:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ── Message (件数表示) ─────────────────────────── */
  #search .pagefind-ui__message {
    padding: calc(14px * var(--pagefind-ui-scale)) 0 calc(8px * var(--pagefind-ui-scale));
    height: auto;
    color: var(--dim);
    font-family: var(--mono);
    font-weight: 400;
    font-size: calc(12px * var(--pagefind-ui-scale));
    letter-spacing: 0.02em;
    border-bottom: 1px dashed var(--rule);
  }
  #search .pagefind-ui__message::before {
    content: "// ";
    color: var(--faint);
  }

  /* ── Results area ──────────────────────────────── */
  #search .pagefind-ui__results-area { margin-top: 0; }
  #search .pagefind-ui__results { padding: 0; }
  #search .pagefind-ui__result {
    padding: calc(18px * var(--pagefind-ui-scale)) 0;
    gap: calc(20px * var(--pagefind-ui-scale));
    border-top: 0;
    border-bottom: 1px solid var(--rule);
  }
  #search .pagefind-ui__result:last-of-type { border-bottom: 1px solid var(--rule); }

  #search .pagefind-ui__result-inner { margin-top: 0; gap: 4px; }

  #search .pagefind-ui__result-title {
    font-family: var(--mono);
    font-weight: 500;
    font-size: calc(15px * var(--pagefind-ui-scale));
    line-height: 1.5;
    position: relative;
    padding-left: 1.4em;
  }
  #search .pagefind-ui__result-title::before {
    content: ">";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  #search .pagefind-ui__result-title a { color: var(--blue); }
  #search .pagefind-ui__result-title a:hover {
    color: var(--blue);
    text-decoration: none;
    border-bottom: 1px solid var(--blue);
  }

  /* nested result(同記事内サブヒット)はサブツリー風に */
  #search .pagefind-ui__result-nested {
    padding-left: calc(20px * var(--pagefind-ui-scale));
    margin-top: 6px;
  }
  #search .pagefind-ui__result-nested .pagefind-ui__result-title {
    padding-left: 1.4em;
    font-size: calc(13px * var(--pagefind-ui-scale));
  }
  #search .pagefind-ui__result-nested .pagefind-ui__result-title::before {
    content: "↳";
    color: var(--faint);
    font-weight: 400;
  }
  #search .pagefind-ui__result-nested .pagefind-ui__result-title a { color: var(--fg); }
  #search .pagefind-ui__result-nested .pagefind-ui__result-title a:hover {
    color: var(--accent);
    border-bottom: 0;
  }

  #search .pagefind-ui__result-excerpt {
    font-family: var(--sans);
    font-size: calc(13.5px * var(--pagefind-ui-scale));
    line-height: 1.7;
    color: var(--fg);
    margin-top: 4px;
    padding-left: 1.4em;
  }
  #search .pagefind-ui__result-excerpt mark {
    background: transparent;
    color: var(--accent);
    font-weight: 600;
    border-bottom: 1px dotted var(--accent2);
    padding: 0;
  }

  #search .pagefind-ui__result-tags {
    margin-top: 8px;
    padding-left: 1.4em;
    gap: 6px;
  }
  #search .pagefind-ui__result-tag {
    background: var(--status);
    border: 1px solid var(--rule);
    color: var(--dim);
    border-radius: 0;
    padding: 1px 7px;
    font-family: var(--mono);
    font-size: calc(11.5px * var(--pagefind-ui-scale));
  }

  /* ── Filter panel(必要になったら) ─────────────── */
  #search .pagefind-ui__filter-panel { margin-top: 14px; }
  #search .pagefind-ui__filter-block {
    border-bottom: 1px solid var(--rule);
    padding: 10px 0;
  }
  #search .pagefind-ui__filter-name {
    font-family: var(--mono);
    font-weight: 500;
    color: var(--fg);
  }
  #search .pagefind-ui__filter-checkbox {
    border: 1px solid var(--rule);
    background: var(--bg);
    border-radius: 0;
  }
  #search .pagefind-ui__filter-checkbox:checked {
    background: var(--accent);
    border-color: var(--accent);
  }
  #search .pagefind-ui__filter-label {
    font-family: var(--mono);
    color: var(--dim);
    font-size: calc(12.5px * var(--pagefind-ui-scale));
  }

  /* ── Load more button ──────────────────────────── */
  #search .pagefind-ui__button {
    margin-top: 20px;
    background: var(--status);
    border: 1px solid var(--rule);
    border-radius: 0;
    color: var(--dim);
    font-family: var(--mono);
    font-weight: 400;
    letter-spacing: 0.04em;
    transition: color 0.1s, border-color 0.1s;
  }
  #search .pagefind-ui__button:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--status);
  }
</style>
