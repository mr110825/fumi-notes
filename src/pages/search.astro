---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="search — /fumi/notes" pageId="search" description="記事の全文検索。">
  <main class="main">
    <div class="left-col">
      <section class="pane hero-pane">
        <div class="pane-header">
          <span class="marker">■</span>
          <span class="title">~/search</span>
          <span class="sep">·</span>
          <span>search.txt</span>
          <span class="spacer"></span>
          <span class="controls">─ □ ×</span>
        </div>
        <div class="pane-body">
          <div class="hero-title"><span class="cursor">❯</span> search</div>
          <p class="hero-tagline">// 全記事を全文検索(タイトル・本文・タグ・コードブロック)</p>
          <div id="search"></div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      resetStyles: false,
      translations: {
        placeholder: '記事を検索...',
        clear_search: 'クリア',
        load_more: 'さらに読み込む',
        search_label: '検索',
        filters_label: 'フィルタ',
        zero_results: '[0]/[1] にヒットなし',
        many_results: '[0]/[1] 件',
        one_result: '[0]/[1] 件',
        alt_search: '[0] にヒットなし。代わりに [1] で検索しました',
        search_suggestion: '[0] にヒットなし。次のクエリを試してください',
        searching: '[0] を検索中...',
      },
    });
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--dim);
    --pagefind-ui-tag: var(--bg-alt, #1a1d21);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: 'JetBrains Mono', 'Noto Sans JP', monospace;
  }
  #search { margin-top: 0.5rem; }
  #search .pagefind-ui__search-input { font-family: var(--pagefind-ui-font); }
  #search .pagefind-ui__result-title a { color: var(--blue); }
  #search .pagefind-ui__result-title a:hover { border-bottom: 1px solid var(--blue); }
  #search .pagefind-ui__result-nested .pagefind-ui__result-title a { color: var(--fg); }
  #search .pagefind-ui__result-nested .pagefind-ui__result-title a:hover { border-bottom: 0; }
</style>
