---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { normalizeTag, tagHref } from '../utils/tags';

const all = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
const sorted = all.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fillDots = '·'.repeat(180);

type Entry = (typeof sorted)[number];
const groupByMonth = new Map<string, Entry[]>();
for (const entry of sorted) {
  const ym = entry.data.pubDate.toISOString().slice(0, 7);
  const arr = groupByMonth.get(ym) ?? [];
  arr.push(entry);
  groupByMonth.set(ym, arr);
}

const monthNames = [
  'january', 'february', 'march', 'april', 'may', 'june',
  'july', 'august', 'september', 'october', 'november', 'december',
];

function monthName(ym: string): string {
  const m = parseInt(ym.slice(5, 7), 10);
  return monthNames[m - 1] ?? '';
}

function mmdd(date: Date): string {
  return date.toISOString().slice(5, 10);
}

const tagCounts = new Map<string, number>();
for (const entry of sorted) {
  for (const tag of entry.data.tags) {
    const key = normalizeTag(tag);
    tagCounts.set(key, (tagCounts.get(key) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([slug, count], i) => ({
    num: String(i + 1).padStart(2, '0'),
    slug,
    label: `#${slug}`,
    count,
  }));

const dailyPosts = new Map<string, number>();
const dailyJots = new Map<string, number>();
for (const entry of sorted) {
  const key = entry.data.pubDate.toISOString().slice(0, 10);
  if (entry.data.type === 'jot') {
    dailyJots.set(key, (dailyJots.get(key) ?? 0) + 1);
  } else {
    dailyPosts.set(key, (dailyPosts.get(key) ?? 0) + 1);
  }
}

const today = new Date();
today.setHours(0, 0, 0, 0);
const lastSunday = new Date(today);
lastSunday.setDate(today.getDate() - today.getDay());

const gridStart = new Date(lastSunday);
gridStart.setDate(lastSunday.getDate() - 51 * 7);

type Cell = {
  date: string;
  posts: number;
  jots: number;
  postLevel: number;
  jotLevel: number;
  future: boolean;
};
const weeks: Cell[][] = [];
for (let w = 0; w < 52; w++) {
  const week: Cell[] = [];
  for (let d = 0; d < 7; d++) {
    const date = new Date(gridStart);
    date.setDate(gridStart.getDate() + w * 7 + d);
    const key = date.toISOString().slice(0, 10);
    const posts = dailyPosts.get(key) ?? 0;
    const jots = dailyJots.get(key) ?? 0;
    week.push({
      date: key,
      posts,
      jots,
      postLevel: posts === 0 ? 0 : Math.min(4, posts),
      jotLevel: jots === 0 ? 0 : Math.min(4, jots),
      future: date > today,
    });
  }
  weeks.push(week);
}

const cellSize = 10;
const cellGap = 2;
const stride = cellSize + cellGap;
const labelHeight = 14;
const labelWidth = 22;
const gridWidth = labelWidth + 52 * stride;
const gridHeight = labelHeight + 7 * stride;

const monthLabels: { x: number; label: string }[] = [];
let lastMonth = -1;
for (let w = 0; w < 52; w++) {
  const firstDay = new Date(gridStart);
  firstDay.setDate(gridStart.getDate() + w * 7);
  const m = firstDay.getMonth();
  if (m !== lastMonth) {
    monthLabels.push({
      x: labelWidth + w * stride,
      label: String(m + 1).padStart(2, '0'),
    });
    lastMonth = m;
  }
}

const cutoff = new Date();
cutoff.setDate(cutoff.getDate() - 30);
let last30Posts = 0;
let last30Jots = 0;
for (const entry of sorted) {
  if (entry.data.pubDate < cutoff) continue;
  if (entry.data.type === 'jot') last30Jots++;
  else last30Posts++;
}
const totalDays = new Set([...dailyPosts.keys(), ...dailyJots.keys()]).size;
---

<BaseLayout pageId="home">
  <main class="main">
    <div class="left-col">
      <section class="pane hero-pane">
        <div class="pane-header">
          <span class="marker">■</span>
          <span class="title">~/home</span>
          <span class="sep">·</span>
          <span>readme.txt</span>
          <span class="spacer"></span>
          <span class="controls">─ □ ×</span>
        </div>
        <div class="pane-body">
          <div class="hero-title"><span class="cursor">❯</span> /fumi/notes</div>
          <p class="hero-tagline">自分と、5年後の自分のための学習ログ。</p>
          <p class="hero-about">
            <span class="comment">// </span>わかった気にならないために、書いて確かめる。
          </p>
        </div>
      </section>

      <section class="pane articles-pane">
        <div class="pane-header">
          <span class="marker">■</span>
          <span class="title">~/posts</span>
          <span class="sep">·</span>
          <span>{sorted.length}/{sorted.length}</span>
          <span class="spacer"></span>
          <span class="controls">─ □ ×</span>
        </div>
        <div class="pane-body scroll">
          {sorted.length === 0 && (
            <p class="articles-empty">
              <span class="comment">// </span>no posts yet — coming soon.
            </p>
          )}
          {[...groupByMonth.entries()].map(([ym, entries]) => (
            <div class="month-group">
              <div class="month-label">
                <span>{ym}</span>
                <span class="month-name">{monthName(ym)}</span>
                <span class="fill-dots">{fillDots}</span>
              </div>
              <ul>
                {entries.map((entry) => (
                  <li class="article-row">
                    <span class="article-date">{mmdd(entry.data.pubDate)}</span>
                    <span class={`article-kind ${entry.data.type}`}>{entry.data.type}</span>
                    <a href={`/posts/${entry.id}/`} class={`article-link ${entry.data.type}`}>
                      {import.meta.env.DEV && entry.data.draft && <span class="draft-badge">[DRAFT]</span>}
                      {entry.data.title}
                    </a>
                    <span class="article-tags">
                      {entry.data.tags.map((t) => (
                        <a href={tagHref(t)} class="article-tag">
                          <span class="hash">#</span>{normalizeTag(t)}
                        </a>
                      ))}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    </div>

    <section class="pane activity-pane">
      <div class="pane-header">
        <span class="marker">■</span>
        <span class="title">~/activity</span>
        <span class="sep">·</span>
        <span>posts/month</span>
        <span class="spacer"></span>
        <span class="controls">─ □ ×</span>
      </div>
      <div class="pane-body">
        <svg
          class="contrib-grid"
          viewBox={`0 0 ${gridWidth} ${gridHeight}`}
          width={gridWidth}
          height={gridHeight}
          role="img"
          aria-label="contribution grid (last 52 weeks)"
        >
          {monthLabels.map((m) => (
            <text x={m.x} y={labelHeight - 4} class="contrib-month">{m.label}</text>
          ))}
          {['M', 'W', 'F'].map((d, i) => (
            <text
              x={labelWidth - 6}
              y={labelHeight + (i * 2 + 1) * stride + cellSize - 2}
              class="contrib-day"
              text-anchor="end"
            >{d}</text>
          ))}
          {weeks.map((week, w) =>
            week.map((cell, d) => {
              const x = labelWidth + w * stride;
              const y = labelHeight + d * stride;
              const tooltip = `${cell.date}: ${cell.posts} post${cell.posts === 1 ? '' : 's'}, ${cell.jots} jot${cell.jots === 1 ? '' : 's'}`;
              if (cell.future) {
                return (
                  <rect x={x} y={y} width={cellSize} height={cellSize} rx={1.5} ry={1.5} class="contrib-cell future">
                    <title>{tooltip}</title>
                  </rect>
                );
              }
              if (cell.posts > 0 && cell.jots > 0) {
                return (
                  <g>
                    <polygon
                      points={`${x},${y} ${x + cellSize},${y} ${x},${y + cellSize}`}
                      class={`contrib-cell post-${cell.postLevel}`}
                    />
                    <polygon
                      points={`${x + cellSize},${y} ${x + cellSize},${y + cellSize} ${x},${y + cellSize}`}
                      class={`contrib-cell jot-${cell.jotLevel}`}
                    />
                    <title>{tooltip}</title>
                  </g>
                );
              }
              const cls =
                cell.posts > 0 ? `post-${cell.postLevel}` :
                cell.jots > 0 ? `jot-${cell.jotLevel}` :
                'level-0';
              return (
                <rect x={x} y={y} width={cellSize} height={cellSize} rx={1.5} ry={1.5} class={`contrib-cell ${cls}`}>
                  <title>{tooltip}</title>
                </rect>
              );
            })
          )}
        </svg>
        <div class="activity-footer">
          <span class="faint">──</span> last 30d:
          <span class="green">+{last30Posts} posts</span>
          <span class="faint"> · </span>
          <span class="orange">+{last30Jots} jot</span>
          <span class="faint"> · </span>
          <span>{totalDays} day{totalDays === 1 ? '' : 's'} active</span>
        </div>
      </div>
    </section>

    <section class="pane tags-pane">
      <div class="pane-header">
        <span class="marker">■</span>
        <span class="title">~/tags</span>
        <span class="sep">·</span>
        <span>{tags.length} tags</span>
        <span class="spacer"></span>
        <span class="controls">─ □ ×</span>
      </div>
      <div class="pane-body">
        {tags.length === 0 && (
          <p class="articles-empty">
            <span class="comment">// </span>no tags yet.
          </p>
        )}
        <ul class="tags-list">
          {tags.map((tag) => (
            <li>
              <a href={tagHref(tag.slug)} class="tag-row">
                <span class="tag-num">{tag.num}</span>
                <span class="tag-label">{tag.label}</span>
                <span class="tag-blurb"></span>
                <span class="tag-count">{tag.count}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-about,
  .hero-about .comment { color: var(--accent); }
</style>
