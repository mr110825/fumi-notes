---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { normalizeTag, tagHref } from '../utils/tags';

const all = await getCollection('blog', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fillDots = '·'.repeat(180);

type Entry = (typeof sorted)[number];
const groupByMonth = new Map<string, Entry[]>();
for (const entry of sorted) {
  const ym = entry.data.pubDate.toISOString().slice(0, 7);
  const arr = groupByMonth.get(ym) ?? [];
  arr.push(entry);
  groupByMonth.set(ym, arr);
}

const monthNames = [
  'january', 'february', 'march', 'april', 'may', 'june',
  'july', 'august', 'september', 'october', 'november', 'december',
];

function monthName(ym: string): string {
  const m = parseInt(ym.slice(5, 7), 10);
  return monthNames[m - 1] ?? '';
}

function mmdd(date: Date): string {
  return date.toISOString().slice(5, 10);
}

const tagCounts = new Map<string, number>();
for (const entry of sorted) {
  for (const tag of entry.data.tags) {
    const key = normalizeTag(tag);
    tagCounts.set(key, (tagCounts.get(key) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([slug, count], i) => ({
    num: String(i + 1).padStart(2, '0'),
    slug,
    label: `#${slug}`,
    count,
  }));

const now = new Date();
type MonthBucket = { ym: string; posts: number; jots: number };
const months: MonthBucket[] = [];
for (let i = 5; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const ym = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  months.push({ ym, posts: 0, jots: 0 });
}
for (const entry of sorted) {
  const ym = entry.data.pubDate.toISOString().slice(0, 7);
  const bucket = months.find((m) => m.ym === ym);
  if (!bucket) continue;
  if (entry.data.type === 'jot') bucket.jots++;
  else bucket.posts++;
}
const barWidth = 8;
const maxTotal = Math.max(1, ...months.map((m) => m.posts + m.jots));
const activityChart = months
  .map((m) => {
    const total = m.posts + m.jots;
    const filled = Math.round((total / maxTotal) * barWidth);
    const bar = '█'.repeat(filled) + '·'.repeat(barWidth - filled);
    return `${m.ym} ${bar} ${total}`;
  })
  .join('\n');

const cutoff = new Date();
cutoff.setDate(cutoff.getDate() - 30);
let last30Posts = 0;
let last30Jots = 0;
for (const entry of sorted) {
  if (entry.data.pubDate < cutoff) continue;
  if (entry.data.type === 'jot') last30Jots++;
  else last30Posts++;
}
---

<BaseLayout pageId="home">
  <main class="main">
    <div class="left-col">
      <section class="pane hero-pane">
        <div class="pane-header">
          <span class="marker">■</span>
          <span class="title">~/home</span>
          <span class="sep">·</span>
          <span>readme.txt</span>
          <span class="spacer"></span>
          <span class="controls">─ □ ×</span>
        </div>
        <div class="pane-body">
          <div class="hero-title"><span class="cursor">❯</span> /fumi/notes</div>
          <p class="hero-tagline">自分と、5年後の自分のための作業ログ。</p>
          <p class="hero-about">
            <span class="comment">// </span>わかった気にならないために、書いて確かめる。
          </p>
        </div>
      </section>

      <section class="pane articles-pane">
        <div class="pane-header">
          <span class="marker">■</span>
          <span class="title">~/posts</span>
          <span class="sep">·</span>
          <span>{sorted.length}/{sorted.length}</span>
          <span class="spacer"></span>
          <span class="controls">─ □ ×</span>
        </div>
        <div class="pane-body scroll">
          {sorted.length === 0 && (
            <p class="articles-empty">
              <span class="comment">// </span>no posts yet — coming soon.
            </p>
          )}
          {[...groupByMonth.entries()].map(([ym, entries]) => (
            <div class="month-group">
              <div class="month-label">
                <span>{ym}</span>
                <span class="month-name">{monthName(ym)}</span>
                <span class="fill-dots">{fillDots}</span>
              </div>
              <ul>
                {entries.map((entry) => (
                  <li class="article-row">
                    <span class="article-date">{mmdd(entry.data.pubDate)}</span>
                    <span class={`article-kind ${entry.data.type}`}>{entry.data.type}</span>
                    <a href={`/posts/${entry.id}/`} class="article-link">
                      {entry.data.type === 'jot' && <span class="jot-dot">•</span>}
                      {entry.data.title}
                    </a>
                    <span class="article-tags">
                      {entry.data.tags.map((t) => (
                        <a href={tagHref(t)} class="article-tag">
                          <span class="hash">#</span>{normalizeTag(t)}
                        </a>
                      ))}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    </div>

    <section class="pane tags-pane">
      <div class="pane-header">
        <span class="marker">■</span>
        <span class="title">~/tags</span>
        <span class="sep">·</span>
        <span>{tags.length} tags</span>
        <span class="spacer"></span>
        <span class="controls">─ □ ×</span>
      </div>
      <div class="pane-body">
        {tags.length === 0 && (
          <p class="articles-empty">
            <span class="comment">// </span>no tags yet.
          </p>
        )}
        <ul class="tags-list">
          {tags.map((tag) => (
            <li>
              <a href={tagHref(tag.slug)} class="tag-row">
                <span class="tag-num">{tag.num}</span>
                <span class="tag-label">{tag.label}</span>
                <span class="tag-blurb"></span>
                <span class="tag-count">{tag.count}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="pane activity-pane">
      <div class="pane-header">
        <span class="marker">■</span>
        <span class="title">~/activity</span>
        <span class="sep">·</span>
        <span>posts/month</span>
        <span class="spacer"></span>
        <span class="controls">─ □ ×</span>
      </div>
      <div class="pane-body">
        <pre class="activity-chart">{activityChart}</pre>
        <div class="activity-footer">
          <span class="faint">──</span> last 30d:
          <span class="green">+{last30Posts} posts</span>
          <span class="faint"> · </span>
          <span class="orange">+{last30Jots} jot</span>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
