---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="about — /fumi/notes" pageId="about">
  <main class="main">
    <div class="left-col">
      <section class="pane hero-pane">
        <div class="pane-header">
          <span class="marker">■</span>
          <span class="title">~/about</span>
          <span class="sep">·</span>
          <span>about.txt</span>
          <span class="spacer"></span>
          <span class="controls">─ □ ×</span>
        </div>
        <div class="pane-body">
          <div class="hero-title"><span class="cursor">❯</span> about</div>
          <p class="hero-tagline">// 管理人</p>fumi
          <p class="hero-tagline">// サイトについて</p>
          自分と、5年後の自分のための作業ログ<br>
          過去に何度か個人ブログを立ち上げては止めた経緯があり、<br>
          今回は「整備より実利用優先」で運用しています。
          </p>

          <p class="hero-tagline">// links<p>
          <p class="hero-about">
            <a href="https://github.com/mr110825/fumi-notes" target="_blank" rel="noopener noreferrer">github: mr110825/fumi-notes</a>
            <br>
            <a href="https://x.com/mr110825" target="_blank" rel="noopener noreferrer">x: mr110825</a>
            <br>
            <a href="/rss.xml" target="_blank" rel="noopener noreferrer">rss</a>
          </p>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .hero-tagline { color: var(--accent); }
  .hero-about a { color: var(--blue); }
  .hero-about a:hover { border-bottom-color: var(--blue); }
</style>
